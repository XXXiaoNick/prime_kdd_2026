# ============================================================================
#  PRIME — .gitignore
# ============================================================================

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.ipynb_checkpoints/

# --- Virtual environments ---------------------------------------------------
.venv/
venv/
env/
ENV/
.conda/

# --- Runtime artifacts (regenerated by the pipeline) ------------------------
outputs/
outputs_*/
logs/
*.log
backup/

# --- Model checkpoints / weights --------------------------------------------
*.pt
*.pth
*.ckpt
checkpoints/

# ============================================================================
#  DATA POLICY
# ----------------------------------------------------------------------------
#  Raw / proprietary financial data is NEVER committed. Auto-generated mock
#  panels and processed caches live under data/<market>/ and are ignored.
#  Only the small, curated example dataset under data/example/ is tracked.
# ============================================================================
/data/*
!/data/README.md
!/data/example/

# Belt-and-suspenders: never track caches / generated panels even if re-added
**/processed_cache/
**/mock_generated/
*.mock_meta.json
*.pkl

# --- OS / editor ------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
